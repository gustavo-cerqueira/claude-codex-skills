# Python bytecode
__pycache__/
*.pyc

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Local agent state (never commit secrets or live config)
.claude/settings.local.json
.codex/
*.local

# Secrets — these skills send uncommitted content to an external model; do not
# let credentials sit untracked in a working tree that gets reviewed.
.env
.env.*
*.pem
*.key
*.p12

# Generated plan/debate artifacts produced when the skills run
plans/

# Temp files used to pass prompts to the counterpart CLI
/tmp/
*.tmp
